{
  "ci": {
    "collect": {
      "staticDistDir": "./dist",
      "url": [
        "http://localhost/index.html",
        "http://localhost/dewalt.html",
        "http://localhost/forro-gesso.html",
        "http://localhost/forro-mineral.html",
        "http://localhost/forro-vinilico.html",
        "http://localhost/pvc-branco.html",
        "http://localhost/pvc-amadeirado.html",
        "http://localhost/divisoria-drywall.html",
        "http://localhost/divisoria-escritorio.html",
        "http://localhost/paredes-drywall.html",
        "http://localhost/manta-termica.html",
        "http://localhost/la-de-vidro.html",
        "http://localhost/la-de-rocha.html",
        "http://localhost/la-de-pet.html",
        "http://localhost/painel-ripado-pvc.html",
        "http://localhost/privacidade.html",
        "http://localhost/404.html"
      ]
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", {"minScore": 0.5}],
        "categories:accessibility": ["error", {"minScore": 0.9}],
        "categories:best-practices": ["error", {"minScore": 0.9}],
        "categories:seo": ["error", {"minScore": 0.9}]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
