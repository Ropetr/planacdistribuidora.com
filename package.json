{
  "name": "planac-distribuidora",
  "version": "2.0.0",
  "description": "Site Planac Distribuidora - SSG com Eleventy",
  "scripts": {
    "build": "npm run build:css && npx @11ty/eleventy",
    "build:css": "cleancss -o src/css/styles.min.css src/css/styles.css && cleancss -o src/css/cookie-consent.min.css src/css/cookie-consent.css",
    "start": "npx @11ty/eleventy --serve",
    "watch": "npx @11ty/eleventy --watch",
    "prebuild": "npm run build:css",
    "test": "playwright test",
    "test:e2e": "playwright test --project=chromium-desktop --project=mobile-chrome",
    "test:mobile": "playwright test --project=mobile-chrome --project=mobile-safari --project=mobile-safari-se",
    "test:visual": "playwright test visual.spec.ts",
    "test:update-snapshots": "playwright test --update-snapshots",
    "test:report": "playwright show-report"
  },
  "keywords": [
    "planac",
    "forros",
    "divisorias",
    "londrina"
  ],
  "author": "Planac Distribuidora",
  "license": "MIT",
  "devDependencies": {
    "@11ty/eleventy": "^3.1.2",
    "clean-css-cli": "^5.6.3",
    "@playwright/test": "^1.40.0"
  }
}