<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <!-- Favicons com máxima compatibilidade -->
    <!-- SVG para navegadores modernos (Chrome, Firefox, Edge) -->
    <link rel="icon" type="image/svg+xml" href="/assets/favicon-32x32.svg">
    <!-- PNG fallback para navegadores que não suportam SVG -->
    <link rel="icon" type="image/png" sizes="32x32" href="/assets/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/assets/favicon-16x16.png">
    <!-- ICO fallback para navegadores antigos (IE, etc) -->
    <link rel="icon" type="image/x-icon" href="/assets/favicon.ico">
    <!-- Apple Touch Icon para iOS -->
    <link rel="apple-touch-icon" sizes="180x180" href="/assets/apple-touch-icon.png">
    <!-- Android/PWA icons -->
    <link rel="icon" type="image/png" sizes="192x192" href="/assets/favicon-192x192.png">
    <link rel="icon" type="image/png" sizes="512x512" href="/assets/favicon-512x512.png">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    
    <!-- DNS Prefetch e Preconnect para recursos externos -->
    <link rel="dns-prefetch" href="//www.googletagmanager.com">
    <link rel="dns-prefetch" href="//www.google-analytics.com">
    <link rel="dns-prefetch" href="//api.whatsapp.com">
    <link rel="preconnect" href="https://www.googletagmanager.com" crossorigin>
    
    <!-- Google Consent Mode v2 -->
    <script>
    window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}
    gtag('consent','default',{'ad_storage':'denied','ad_user_data':'denied','ad_personalization':'denied','analytics_storage':'denied','functionality_storage':'granted','security_storage':'granted','wait_for_update':500});
    </script>
    
    <!-- Google Tag Manager - Carregado de forma otimizada -->
    <script>(function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src='https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);})(window,document,'script','dataLayer','{{ site.gtmId }}');</script>
    
    <!-- Preload de recursos críticos -->
    <link rel="preload" href="/assets/fonts/barlow-400.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/assets/fonts/barlow-700.woff2" as="font" type="font/woff2" crossorigin>
    {% if preloadImage %}<link rel="preload" href="{{ preloadImage }}" as="image" type="image/{{ preloadImageType | default('avif') }}" fetchpriority="high">{% endif %}
    
    <!-- Meta tags SEO -->
    <title>{{ title }}</title>
    
    <!-- JavaScript do Menu (Inline para evitar FOUC) -->
    <script>function toggleMenu(){const m=document.getElementById("mobileMenu"),h=document.querySelector(".hamburger"),a=m.classList.toggle("active");h.setAttribute("aria-expanded",a);m.setAttribute("aria-hidden",!a);a?document.addEventListener("click",closeMenuOnClickOutside):document.removeEventListener("click",closeMenuOnClickOutside)}function closeMenuOnClickOutside(e){const m=document.getElementById("mobileMenu"),h=document.querySelector(".hamburger");if(!m.contains(e.target)&&!h.contains(e.target)){m.classList.remove("active");h.setAttribute("aria-expanded","false");m.setAttribute("aria-hidden","true");document.removeEventListener("click",closeMenuOnClickOutside)}}function toggleDropdown(b){const d=b.parentElement,a=d.classList.contains("active");document.querySelectorAll(".mobile-dropdown.active").forEach(x=>{if(x!==d)x.classList.remove("active")});d.classList.toggle("active",!a)}</script>
    
    <meta name="description" content="{{ description }}">
    <meta name="keywords" content="{{ keywords }}">
    <meta name="author" content="{{ site.name }}">
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <link rel="canonical" href="{{ site.url }}{{ canonical | default(page.url) }}">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.url }}{{ page.url }}">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ ogDescription | default(description) }}">
    <meta property="og:image" content="{{ site.url }}{{ ogImage | default('/assets/hero-1.avif') }}">
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:locale" content="pt_BR">
    <meta property="og:site_name" content="{{ site.name }}">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ twitterDescription | default(description) }}">
    <meta name="twitter:image" content="{{ site.url }}{{ twitterImage | default('/assets/hero-1.avif') }}">
    
    <!-- Theme Color para mobile -->
    <meta name="theme-color" content="{{ site.themeColor }}">
    <meta name="msapplication-TileColor" content="{{ site.themeColor }}">
    
    <!-- Critical CSS Inline - CORRIGIDO: logo 60px, font-weight 500 -->
    <style>
@font-face{font-family:'Barlow';font-style:normal;font-weight:400;font-display:swap;src:url('/assets/fonts/barlow-400.woff2') format('woff2')}
@font-face{font-family:'Barlow';font-style:normal;font-weight:600;font-display:swap;src:url('/assets/fonts/barlow-600.woff2') format('woff2')}
@font-face{font-family:'Barlow';font-style:normal;font-weight:700;font-display:swap;src:url('/assets/fonts/barlow-700.woff2') format('woff2')}
@font-face{font-family:'Barlow';font-style:normal;font-weight:800;font-display:swap;src:url('/assets/fonts/barlow-800.woff2') format('woff2')}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Barlow',-apple-system,BlinkMacSystemFont,sans-serif;line-height:1.6;color:#333}
.header{background:#fff;padding:12px 20px;position:sticky;top:0;z-index:1000;box-shadow:0 1px 3px rgba(0,0,0,.1);min-height:84px;contain:layout style}
.header-container{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;min-height:60px}
.logo img{height:60px;width:180px;display:block}
.nav-desktop{display:flex;gap:32px;align-items:center}
.nav-link{color:#333;text-decoration:none;font-size:15px;font-weight:500}
.btn-header{background:#AA000E;color:#fff;padding:10px 20px;border-radius:4px;text-decoration:none;font-weight:600;font-size:14px}
.hamburger{display:none;background:none;border:none;cursor:pointer;padding:8px}
.hamburger span{display:block;width:24px;height:2px;background:#333;margin-bottom:6px}
.hamburger span:last-child{margin-bottom:0}
.nav-mobile{display:none;position:absolute;top:100%;left:0;right:0;background:#fff;border-top:1px solid #eee;box-shadow:0 4px 12px rgba(0,0,0,.1);padding:20px}
.nav-mobile.active{display:block}
.hero-carousel{height:45vh;min-height:320px;max-height:400px;position:relative;overflow:hidden;contain:layout style paint}
.hero-slides{position:absolute;top:0;left:0;width:100%;height:100%}
.hero-slide{position:absolute;top:0;left:0;width:100%;height:100%;opacity:0;transition:opacity 1s ease-in-out;will-change:opacity}
.hero-slide::after{content:'';position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.45)}
.hero-slide.active{opacity:1}
.hero-img{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;z-index:0}
.hero-carousel .hero-content{position:relative;z-index:10;max-width:800px;margin:0 auto;text-align:center;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:40px 20px 60px}
.hero-carousel h1{font-size:clamp(26px,4.5vw,40px);font-weight:800;color:#fff;margin-bottom:16px;line-height:1.2;text-shadow:0 2px 4px rgba(0,0,0,.4)}
.hero-carousel p{font-size:16px;color:rgba(255,255,255,.95);max-width:520px;margin:0 auto 24px;line-height:1.6;text-shadow:0 1px 3px rgba(0,0,0,.4)}
.btn-hero{background:#AA000E;color:#fff;padding:12px 28px;border-radius:4px;text-decoration:none;font-weight:600;font-size:14px}
.hero-dots{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);z-index:10;display:flex;gap:10px}
.hero-dot{width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,.5);cursor:pointer}
.hero-dot.active{background:#fff;transform:scale(1.2)}
.skip-link{position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;z-index:-999}
.skip-link:focus{position:fixed;left:50%;transform:translateX(-50%);top:10px;width:auto;height:auto;overflow:visible;z-index:9999;background:#AA000E;color:#fff;padding:12px 24px;border-radius:4px;font-weight:600;text-decoration:none}
@media(max-width:768px){.nav-desktop{display:none}.hamburger{display:block}body{padding-bottom:80px}}
    </style>
    
    <!-- CSS principal -->
    <link rel="stylesheet" href="/css/styles.min.css">
    
    <!-- Schema.org Organization + LocalBusiness -->
    <script type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": ["Organization", "LocalBusiness"],
      "@id": "{{ site.url }}/#organization",
      "name": "{{ site.name }}",
      "alternateName": "Planac",
      "description": "{{ site.description }}",
      "url": "{{ site.url }}",
      "logo": {
        "@type": "ImageObject",
        "url": "{{ site.url }}/assets/logo.svg",
        "width": "180",
        "height": "60"
      },
      "image": "{{ site.url }}/assets/logo.svg",
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "{{ site.address.street }}",
        "addressLocality": "{{ site.address.city }}",
        "addressRegion": "{{ site.address.state }}",
        "postalCode": "{{ site.address.postalCode }}",
        "addressCountry": "BR"
      },
      "geo": {
        "@type": "GeoCoordinates",
        "latitude": "-23.3045",
        "longitude": "-51.1696"
      },
      "telephone": "{{ site.phone }}",
      "email": "{{ site.email }}",
      "openingHoursSpecification": [
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday"],
          "opens": "08:00",
          "closes": "18:00"
        },
        {
          "@type": "OpeningHoursSpecification",
          "dayOfWeek": "Saturday",
          "opens": "08:00",
          "closes": "12:00"
        }
      ],
      "priceRange": "$$",
      "currenciesAccepted": "BRL",
      "paymentAccepted": "Dinheiro, Cartão de Crédito, Cartão de Débito, PIX, Boleto",
      "sameAs": [
        "{{ site.social.instagram }}",
        "{{ site.social.facebook }}"
      ],
      "contactPoint": [
        {
          "@type": "ContactPoint",
          "telephone": "+55-43-3029-5750",
          "contactType": "customer service",
          "areaServed": "BR",
          "availableLanguage": "Portuguese"
        },
        {
          "@type": "ContactPoint",
          "telephone": "+55-43-98418-2582",
          "contactType": "sales",
          "areaServed": "BR",
          "availableLanguage": "Portuguese"
        }
      ],
      "areaServed": [
        {"@type": "City", "name": "Londrina"},
        {"@type": "City", "name": "Cambé"},
        {"@type": "City", "name": "Ibiporã"},
        {"@type": "City", "name": "Rolândia"},
        {"@type": "City", "name": "Arapongas"},
        {"@type": "City", "name": "Apucarana"},
        {"@type": "City", "name": "Jataizinho"},
        {"@type": "City", "name": "Sertanópolis"},
        {"@type": "City", "name": "Bela Vista do Paraíso"},
        {"@type": "City", "name": "Primeiro de Maio"},
        {"@type": "City", "name": "Assaí"},
        {"@type": "City", "name": "Jaguapitã"},
        {"@type": "City", "name": "Tamarana"},
        {"@type": "City", "name": "Sabáudia"},
        {"@type": "City", "name": "Pitangueiras"},
        {"@type": "City", "name": "Florestópolis"},
        {"@type": "City", "name": "Porecatu"},
        {"@type": "City", "name": "Alvorada do Sul"},
        {"@type": "City", "name": "Centenário do Sul"},
        {"@type": "City", "name": "Guaraci"},
        {"@type": "City", "name": "Uraí"},
        {"@type": "City", "name": "Jandaia do Sul"},
        {"@type": "City", "name": "Mandaguari"},
        {"@type": "City", "name": "Astorga"},
        {"@type": "City", "name": "Cornélio Procópio"},
        {"@type": "City", "name": "Prado Ferreira"},
        {"@type": "City", "name": "Miraselva"},
        {"@type": "City", "name": "Rancho Alegre"},
        {"@type": "City", "name": "Santa Mariana"},
        {"@type": "City", "name": "São Sebastião da Amoreira"},
        {"@type": "City", "name": "Nova Santa Bárbara"},
        {"@type": "City", "name": "Califórnia"},
        {"@type": "City", "name": "Cambira"},
        {"@type": "City", "name": "Mauá da Serra"}
      ]
    }
    </script>
    
    {% if schemaProduct %}
    <!-- Schema.org Product -->
    <script type="application/ld+json">
    {{ schemaProduct | safe }}
    </script>
    {% endif %}
    
    {% if schemaBreadcrumb %}
    <!-- Schema.org BreadcrumbList -->
    <script type="application/ld+json">
    {{ schemaBreadcrumb | safe }}
    </script>
    {% endif %}
</head>
<body>
<!-- Google Tag Manager (noscript) -->
<noscript><iframe src="https://www.googletagmanager.com/ns.html?id={{ site.gtmId }}" height="0" width="0" style="display:none;visibility:hidden" loading="lazy"></iframe></noscript>

{% include "components/header.njk" %}

<main id="main-content">
{{ content | safe }}
</main>

{% include "components/footer.njk" %}

<!-- JavaScript carregado com defer para não bloquear renderização -->
<script src="/js/main.min.js" defer></script>

{% include "components/cookie-consent.njk" %}
<link rel="stylesheet" href="/css/cookie-consent.css">
<!-- CORRIGIDO: defer adicionado para evitar bloqueio do parser -->
<script src="/js/cookie-consent.js" defer></script>
</body>
</html>
