    <meta charset="UTF-8">
    <!-- Data Layer - Inicialização -->
    <script data-cfasync="false">
    window.dataLayer = window.dataLayer || [];
    dataLayer.push({
        'page_type': '{{ pageType | default("page") }}',
        'page_title': '{{ title }}',
        'page_url': '{{ site.url }}{{ page.url }}',
        'site_name': '{{ site.name }}',
        'site_phone': '{{ site.phone }}',
        'site_whatsapp': '{{ site.whatsapp }}',
        'business_category': 'materiais_construcao',
        'business_city': '{{ site.address.city }}',
        'business_state': '{{ site.address.state }}'
    });
    </script>
    <!-- End Data Layer -->


    <!-- Google Consent Mode v2 - DEVE vir antes do GTM -->
    <script data-cfasync="false">
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('consent', 'default', {
        'ad_storage': 'granted',
        'ad_user_data': 'granted',
        'ad_personalization': 'granted',
        'analytics_storage': 'granted',
        'functionality_storage': 'granted',
        'personalization_storage': 'granted',
        'security_storage': 'granted',
        'wait_for_update': 500
    });
    </script>
    <!-- End Google Consent Mode v2 -->

