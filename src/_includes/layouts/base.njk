            https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/{{ preloadHeroCF }}-320/public 320w,
            https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/{{ preloadHeroCF }}-480/public 480w,
            https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/{{ preloadHeroCF }}-1024/public 1024w,
            https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/{{ preloadHeroCF }}-1920/public 1920w"
          imagesizes="100vw"
          fetchpriority="high">
    {% elif preloadBannerCF %}
    <link rel="preload" as="image" 
          href="https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/{{ preloadBannerCF }}-1920/public"
          imagesrcset="
            https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/{{ preloadBannerCF }}-320/public 320w,
            https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/{{ preloadBannerCF }}-480/public 480w,
            https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/{{ preloadBannerCF }}-1024/public 1024w,
            https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/{{ preloadBannerCF }}-1920/public 1920w"
          imagesizes="100vw"
          fetchpriority="high">
    {% elif preloadBanner %}
    <link rel="preload" as="image" 
          href="/cdn-cgi/image/width=1920,quality=80,format=auto/assets/banners/1920x700/{{ preloadBanner }}"
          imagesrcset="
            /cdn-cgi/image/width=320,quality=80,format=auto/assets/banners/320x400/{{ preloadBanner }} 320w,
            /cdn-cgi/image/width=480,quality=80,format=auto/assets/banners/480x400/{{ preloadBanner }} 480w,
            /cdn-cgi/image/width=1024,quality=80,format=auto/assets/banners/1024x500/{{ preloadBanner }} 1024w,
            /cdn-cgi/image/width=1920,quality=80,format=auto/assets/banners/1920x700/{{ preloadBanner }} 1920w,
            /cdn-cgi/image/width=2550,quality=80,format=auto/assets/banners/2550x700/{{ preloadBanner }} 2550w"
          imagesizes="100vw"
          fetchpriority="high"
          type="image/avif">
    {% elif preloadHero %}
    <link rel="preload" as="image" 
          href="/cdn-cgi/image/width=1920,quality=80,format=auto/assets/hero/1920x700/{{ preloadHero }}"
          imagesrcset="
            /cdn-cgi/image/width=320,quality=80,format=auto/assets/hero/320x400/{{ preloadHero }} 320w,
            /cdn-cgi/image/width=480,quality=80,format=auto/assets/hero/480x400/{{ preloadHero }} 480w,
            /cdn-cgi/image/width=1024,quality=80,format=auto/assets/hero/1024x500/{{ preloadHero }} 1024w,
            /cdn-cgi/image/width=1920,quality=80,format=auto/assets/hero/1920x700/{{ preloadHero }} 1920w,
            /cdn-cgi/image/width=2550,quality=80,format=auto/assets/hero/2550x700/{{ preloadHero }} 2550w"
          imagesizes="100vw"
          fetchpriority="high"
          type="image/avif">
    {% elif preloadImage %}<link rel="preload" href="{{ preloadImage }}" as="image" type="image/{{ preloadImageType | default('avif') }}" fetchpriority="high">{% endif %}
    
    <!-- Meta tags SEO -->
    <title>{{ title }}</title>
    
    <!-- JavaScript do Menu (Inline para evitar FOUC) -->
    <script>function toggleMenu(){const m=document.getElementById("mobileMenu"),h=document.querySelector(".hamburger"),a=m.classList.toggle("active");h.setAttribute("aria-expanded",a);m.setAttribute("aria-hidden",!a);a?document.addEventListener("click",closeMenuOnClickOutside):document.removeEventListener("click",closeMenuOnClickOutside)}function closeMenuOnClickOutside(e){const m=document.getElementById("mobileMenu"),h=document.querySelector(".hamburger");if(!m.contains(e.target)&&!h.contains(e.target)){m.classList.remove("active");h.setAttribute("aria-expanded","false");m.setAttribute("aria-hidden","true");document.removeEventListener("click",closeMenuOnClickOutside)}}function toggleDropdown(b){const d=b.parentElement,a=d.classList.contains("active");document.querySelectorAll(".mobile-dropdown.active").forEach(x=>{if(x!==d)x.classList.remove("active")});d.classList.toggle("active",!a)}</script>
    
    <meta name="description" content="{{ description }}">
    <meta name="keywords" content="{{ keywords }}">
    <meta name="author" content="{{ site.name }}">
    <meta name="robots" content="index, follow, max-image-preview:large, max-snippet:-1, max-video-preview:-1">
    <link rel="canonical" href="{{ site.url }}{{ (canonical | default(page.url)) | prettyUrl }}">
    <link rel="alternate" hreflang="pt-BR" href="{{ site.url }}{{ (canonical | default(page.url)) | prettyUrl }}">
    <link rel="alternate" hreflang="x-default" href="{{ site.url }}{{ (canonical | default(page.url)) | prettyUrl }}">
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="{{ site.url }}{{ page.url | prettyUrl }}">
    <meta property="og:title" content="{{ title }}">
    <meta property="og:description" content="{{ ogDescription | default(description) }}">
    {% if ogImage %}<meta property="og:image" content="{{ ogImage }}">
    {% elif preloadBannerCF %}<meta property="og:image" content="https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/{{ preloadBannerCF }}-1920/public">
    {% else %}<meta property="og:image" content="https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/hero-forro-gesso-1920/public">{% endif %}
    <meta property="og:image:width" content="1200">
    <meta property="og:image:height" content="630">
    <meta property="og:locale" content="pt_BR">
    <meta property="og:site_name" content="{{ site.name }}">
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="{{ title }}">
    <meta name="twitter:description" content="{{ twitterDescription | default(description) }}">
    {% if twitterImage %}<meta name="twitter:image" content="{{ twitterImage }}">
    {% elif preloadBannerCF %}<meta name="twitter:image" content="https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/{{ preloadBannerCF }}-1920/public">
    {% else %}<meta name="twitter:image" content="https://imagedelivery.net/XawtofIFluGyh9zwRP6h6A/hero-forro-gesso-1920/public">{% endif %}
    
    <!-- Theme Color para mobile -->
    <meta name="theme-color" content="{{ site.themeColor }}">
    <meta name="msapplication-TileColor" content="{{ site.themeColor }}">
    
    <!-- Critical CSS Inline - CORRIGIDO: logo 60px, font-weight 500 -->
    <style>
@font-face{font-family:'Barlow';font-style:normal;font-weight:400;font-display:swap;src:url('/assets/fonts/barlow-400.woff2') format('woff2')}
@font-face{font-family:'Barlow';font-style:normal;font-weight:600;font-display:swap;src:url('/assets/fonts/barlow-600.woff2') format('woff2')}
@font-face{font-family:'Barlow';font-style:normal;font-weight:700;font-display:swap;src:url('/assets/fonts/barlow-700.woff2') format('woff2')}
@font-face{font-family:'Barlow';font-style:normal;font-weight:800;font-display:swap;src:url('/assets/fonts/barlow-800.woff2') format('woff2')}
*{margin:0;padding:0;box-sizing:border-box}
html{scroll-behavior:smooth}
body{font-family:'Barlow',-apple-system,BlinkMacSystemFont,sans-serif;line-height:1.6;color:#333;padding-top:84px}
.header{background:#fff;padding:12px 20px;position:fixed;top:0;left:0;right:0;z-index:1000;box-shadow:0 1px 3px rgba(0,0,0,.1);min-height:84px;contain:layout style;border-bottom:1.5px solid #ED282E}
.header-container{max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;min-height:60px}
.logo img{height:60px;width:180px;display:block}
.nav-desktop{display:flex;gap:32px;align-items:center}
.nav-link{color:#333;text-decoration:none;font-size:15px;font-weight:500}
.btn-header{background:#ED282E;color:#fff;padding:10px 20px;border-radius:4px;text-decoration:none;font-weight:600;font-size:14px}
.hamburger{display:none;background:none;border:none;cursor:pointer;padding:8px}
.hamburger span{display:block;width:24px;height:2px;background:#333;margin-bottom:6px}
.hamburger span:last-child{margin-bottom:0}
.nav-mobile{display:none;position:absolute;top:100%;left:0;right:0;background:#fff;border-top:1px solid #eee;box-shadow:0 4px 12px rgba(0,0,0,.1);padding:20px}
.nav-mobile.active{display:block}
.hero-carousel{width:100%;height:45vh;min-height:320px;position:relative;overflow:hidden;contain:layout style paint}
.hero-slides{position:absolute;top:0;left:0;width:100%;height:100%}
.hero-slide{position:absolute;top:0;left:0;width:100%;height:100%;opacity:0;transition:opacity 1s ease-in-out;will-change:opacity}
.hero-slide::after{content:'';position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.45)}
.hero-slide.active{opacity:1}
.hero-img{position:absolute;top:0;left:0;width:100%;height:100%;object-fit:cover;z-index:0}
.hero-carousel .hero-content{position:relative;z-index:10;max-width:800px;margin:0 auto;text-align:center;height:100%;display:flex;flex-direction:column;justify-content:center;align-items:center;padding:40px 20px 60px}
.hero-carousel h1{font-size:clamp(26px,4.5vw,40px);font-weight:800;color:#fff;margin-bottom:16px;line-height:1.2;text-shadow:0 2px 4px rgba(0,0,0,.4)}
.banner h1{font-size:clamp(28px,5vw,44px);font-weight:800;color:#1a1a1a;margin-bottom:12px}
.cookie-banner{position:fixed;bottom:0;left:0;right:0;background:#fff;box-shadow:0 -4px 20px rgba(0,0,0,0.15);z-index:99999;padding:20px;transform:translateY(100%);transition:transform 0.4s ease}
.cookie-banner.active{transform:translateY(0)}
.cookie-banner-container{max-width:1200px;margin:0 auto;display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:20px}
.cookie-banner-text{flex:1;min-width:280px}
.cookie-banner-text .cookie-title{margin:0 0 8px;font-size:18px;color:#333;display:flex;align-items:center;gap:8px}
.cookie-banner-text .cookie-title svg{width:24px;height:24px;fill:#ED282E}
.cookie-banner-text p{margin:0;font-size:14px;color:#666;line-height:1.5}
.cookie-banner-text a{color:#ED282E}
.cookie-banner-buttons{display:flex;flex-wrap:wrap;gap:10px}
.cookie-btn{padding:10px 20px;border-radius:6px;font-size:14px;font-weight:600;cursor:pointer;transition:all 0.2s;border:none}
.cookie-btn-accept{background:#ED282E;color:#fff}
.cookie-btn-reject{background:#f5f5f5;color:#333}
.cookie-btn-config{background:transparent;color:#ED282E;border:1px solid #ED282E}
.cookie-modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.6);z-index:100000;display:none;align-items:center;justify-content:center;padding:20px}
.cookie-modal-overlay.active{display:flex}
.cookie-modal{background:#fff;border-radius:12px;max-width:600px;width:100%;max-height:90vh;overflow-y:auto}
.hero-carousel p{font-size:16px;color:rgba(255,255,255,.95);max-width:520px;margin:0 auto 24px;line-height:1.6;text-shadow:0 1px 3px rgba(0,0,0,.4)}
.btn-hero{background:#ED282E;color:#fff;padding:12px 28px;border-radius:4px;text-decoration:none;font-weight:600;font-size:14px}
.hero-dots{position:absolute;bottom:16px;left:50%;transform:translateX(-50%);z-index:10;display:flex;gap:10px}
.hero-dot{width:10px;height:10px;border-radius:50%;background:rgba(255,255,255,.5);cursor:pointer}
.hero-dot.active{background:#fff;transform:scale(1.2)}
.breadcrumb{background:#fff;padding:16px 20px;border-bottom:1px solid #eee}
.breadcrumb-container{max-width:1200px;margin:0 auto}
.breadcrumb-list{font-size:14px;color:#666}
.breadcrumb-list a{color:#ED282E;text-decoration:none}
.breadcrumb-sep{margin:0 8px;color:#767676}
.banner{position:relative;width:100%;overflow:hidden;display:flex;align-items:center;justify-content:center}
.banner-img{width:100%;height:100%;object-fit:cover;position:absolute;top:0;left:0}
.banner-overlay{position:absolute;top:0;left:0;width:100%;height:100%;background:rgba(0,0,0,.45);z-index:1}
.banner-content{position:relative;z-index:2;text-align:center;padding:40px 20px}
.skip-link{position:absolute;left:-9999px;top:auto;width:1px;height:1px;overflow:hidden;z-index:-999}
.skip-link:focus{position:fixed;left:50%;transform:translateX(-50%);top:10px;width:auto;height:auto;overflow:visible;z-index:9999;background:#ED282E;color:#fff;padding:12px 24px;border-radius:4px;font-weight:600;text-decoration:none}
@media(max-width:768px){.nav-desktop{display:none}.hamburger{display:block}body{padding-bottom:80px}}
    </style>
    
