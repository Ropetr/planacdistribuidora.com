                <div class="form-group"><label for="telefone">Telefone</label><input type="tel" id="telefone" name="telefone" required></div>
                <div class="form-group"><label for="cidade">Cidade</label><input type="text" id="cidade" name="cidade" required></div>
                <div class="form-group"><label for="tipo">Tipo de projeto</label><select id="tipo" name="tipo"><option value="">Selecione</option><option value="Residencial">Residencial</option><option value="Comercial">Comercial</option><option value="Industrial">Industrial</option><option value="Outro">Outro</option></select></div>
                <div class="form-group">
                    <label for="arquivo">Anexar projeto (opcional)</label>
                    <input type="file" id="arquivo" name="arquivo" accept=".pdf,.jpg,.jpeg,.png,.dwg,.dxf,.xlsx,.xls,.doc,.docx" style="padding: 10px; border: 2px dashed #ccc; border-radius: 8px; background: #f9f9f9; cursor: pointer;">
                    <small style="color: #666; display: block; margin-top: 5px;">PDF, imagens, DWG, planilhas (máx. 100MB)</small>
                </div>
                <div class="form-group"><label for="mensagem">Detalhes do projeto</label><textarea id="mensagem" name="mensagem" placeholder="Descreva seu projeto: área aproximada, tipo de ambiente, necessidades específicas..." required></textarea></div>
                <button type="submit" class="btn-submit" style="background: #ED282E;" id="btnSubmit">Enviar Projeto</button>
                <div id="uploadStatus" style="display: none; margin-top: 10px; padding: 10px; border-radius: 8px; text-align: center;"></div>
            </form>
        </div>
    </section>


